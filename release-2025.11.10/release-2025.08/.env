# Postgres (HAPI)
PG_HAPI_DB=hapi
PG_HAPI_USER=admin
PG_HAPI_PASS=admin

# Postgres (Keycloak)
PG_KC_DB=keycloak
PG_KC_USER=keycloak
PG_KC_PASS=keycloak

# Ports
HAPI_EXT_PORT=8081
KC_EXTERNAL_PORT=8080

# Keycloak realm
REALM=fhir-realm

# 供容器內互連使用的 Keycloak 基底位址
KC_BASE=http://keycloak:8080

# （目前 HAPI 不驗證，可保留或留白；正式上線再啟用）
JWK_SET_URI=${KC_BASE}/realms/${REALM}/protocol/openid-connect/certs
ISSUER_URI=

# ===== oauth2-proxy 用（8083）===== hapi-ui 要建立
OAUTH2_CLIENT_ID=hapi-ui
OAUTH2_CLIENT_SECRET=CyBFcwWHvbae0WFrTE4YNIdDTtEAQAJr
